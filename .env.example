# =============================================================================
# IAgencia Desktop — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Most settings have sensible defaults for Docker usage.
# =============================================================================

# Display configuration (used inside the container)
DISPLAY=:0

# Port the iagenciad API listens on (inside the container)
# PORT=9990

# Log level for NestJS (log, error, warn, debug, verbose)
# LOG_LEVEL=log

# Screenshot directory (inside the container)
# SCREENSHOT_DIR=/tmp/iagencia-screenshots
